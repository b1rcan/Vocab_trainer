<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/bg_page">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="@color/orange" android:padding="16dp" android:paddingTop="40dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Tekrar" android:textColor="@color/white"
            android:textSize="18sp" android:textStyle="bold"/>
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="14dp">

        <LinearLayout android:id="@+id/btnRevAll" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:background="@drawable/bg_card"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:padding="14dp" android:layout_marginBottom="10dp"
            android:clickable="true" android:focusable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="📚" android:textSize="22sp" android:layout_marginEnd="14dp"/>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Tüm Kelimeleri Tekrar Et" android:textColor="@color/text_main"
                    android:textSize="14sp" android:textStyle="bold"/>
                <TextView android:id="@+id/tvAllCount" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="248 kelime"
                    android:textColor="@color/text_gray" android:textSize="12sp"/>
            </LinearLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="›" android:textColor="@color/orange" android:textSize="20sp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/btnRevWeak" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:background="@drawable/bg_card"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:padding="14dp" android:layout_marginBottom="10dp"
            android:clickable="true" android:focusable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="⚠️" android:textSize="22sp" android:layout_marginEnd="14dp"/>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Zayıf Kelimeleri Tekrar Et" android:textColor="@color/text_main"
                    android:textSize="14sp" android:textStyle="bold"/>
                <TextView android:id="@+id/tvWeakCount" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="Yükleniyor..."
                    android:textColor="@color/text_gray" android:textSize="12sp"/>
            </LinearLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="›" android:textColor="@color/orange" android:textSize="20sp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/btnRevDaily" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:background="@drawable/bg_orange_btn"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:padding="14dp" android:clickable="true" android:focusable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🗓️" android:textSize="22sp" android:layout_marginEnd="14dp"/>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Günlük Tekrar" android:textColor="@color/white"
                    android:textSize="14sp" android:textStyle="bold"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Bugün için 20 kelime" android:textColor="#FFDDBB" android:textSize="12sp"/>
            </LinearLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="›" android:textColor="@color/white" android:textSize="20sp"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
