<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/bg_page">

    <!-- Turuncu header -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="@color/orange" android:orientation="vertical"
        android:padding="16dp" android:paddingTop="40dp">

        <TextView android:id="@+id/tvGreeting" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text=""
            android:textColor="@color/white" android:textSize="18sp" android:textStyle="bold"/>

        <TextView android:id="@+id/tvDailyGoal" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/daily_goal" android:textColor="#FFDDBB"
            android:textSize="13sp" android:layout_marginTop="2dp"/>
    </LinearLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:scrollbars="none">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="14dp">

            <!-- İlerleme kartı -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@drawable/bg_card" android:orientation="vertical"
                android:padding="14dp" android:layout_marginBottom="10dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/daily_progress" android:textColor="@color/text_gray"
                    android:textSize="12sp" android:layout_marginBottom="8dp"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <ProgressBar android:id="@+id/progressDaily"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="0dp" android:layout_height="8dp"
                        android:layout_weight="1" android:progressDrawable="@drawable/progress_bar"
                        android:max="100" android:progress="0" android:layout_marginEnd="10dp"/>
                    <TextView android:id="@+id/tvProgress" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="0/20"
                        android:textColor="@color/orange" android:textSize="13sp" android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>

            <!-- İstatistik kutuları -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="10dp">

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:background="@drawable/bg_card"
                    android:orientation="vertical" android:padding="12dp"
                    android:gravity="center" android:layout_marginEnd="5dp">
                    <TextView android:id="@+id/tvLearnedCount" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="0"
                        android:textColor="@color/text_main" android:textSize="22sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/learned_label" android:textColor="@color/text_gray" android:textSize="11sp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:background="@drawable/bg_card"
                    android:orientation="vertical" android:padding="12dp"
                    android:gravity="center" android:layout_marginHorizontal="5dp">
                    <TextView android:id="@+id/tvAccuracy" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="0%"
                        android:textColor="@color/orange" android:textSize="22sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/accuracy_label" android:textColor="@color/text_gray" android:textSize="11sp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:background="@drawable/bg_card"
                    android:orientation="vertical" android:padding="12dp"
                    android:gravity="center" android:layout_marginStart="5dp">
                    <TextView android:id="@+id/tvStreak" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="0"
                        android:textColor="@color/text_main" android:textSize="22sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/streak_label" android:textColor="@color/text_gray" android:textSize="11sp"/>
                </LinearLayout>
            </LinearLayout>

            <Button android:id="@+id/btnStart"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:background="@drawable/bg_orange_btn" android:text="@string/start_learning"
                android:textColor="@color/white" android:textSize="15sp" android:textStyle="bold"
                android:stateListAnimator="@null" android:layout_marginBottom="16dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/recent_words_label" android:textColor="@color/text_gray"
                android:textSize="12sp" android:layout_marginBottom="8dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvRecentWords"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"/>
        </LinearLayout>
    </ScrollView>

    <!-- Alt navigasyon çubuğu -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
        android:background="@color/white" android:orientation="horizontal"
        android:gravity="center_vertical"
        android:elevation="4dp">

        <LinearLayout android:id="@+id/navHome" android:layout_width="0dp"
            android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center"
            android:clickable="true" android:focusable="true">
            <ImageView android:layout_width="22dp" android:layout_height="22dp"
                android:src="@drawable/ic_home"
                android:tint="@color/orange"
                android:contentDescription="Ana Sayfa"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/nav_home" android:textColor="@color/orange" android:textSize="10sp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navWords" android:layout_width="0dp"
            android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center"
            android:clickable="true" android:focusable="true">
            <ImageView android:layout_width="22dp" android:layout_height="22dp"
                android:src="@drawable/ic_book"
                android:tint="@color/text_light"
                android:contentDescription="Kelimeler"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/nav_words" android:textColor="@color/text_light" android:textSize="10sp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navQuiz" android:layout_width="0dp"
            android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center"
            android:clickable="true" android:focusable="true">
            <ImageView android:layout_width="22dp" android:layout_height="22dp"
                android:src="@drawable/ic_quiz"
                android:tint="@color/text_light"
                android:contentDescription="Quiz"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/nav_quiz" android:textColor="@color/text_light" android:textSize="10sp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navReview" android:layout_width="0dp"
            android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center"
            android:clickable="true" android:focusable="true">
            <ImageView android:layout_width="22dp" android:layout_height="22dp"
                android:src="@drawable/ic_replay"
                android:tint="@color/text_light"
                android:contentDescription="Tekrar"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/nav_review" android:textColor="@color/text_light" android:textSize="10sp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navProfile" android:layout_width="0dp"
            android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center"
            android:clickable="true" android:focusable="true">
            <ImageView android:layout_width="22dp" android:layout_height="22dp"
                android:src="@drawable/ic_person"
                android:tint="@color/text_light"
                android:contentDescription="Profil"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/nav_profile" android:textColor="@color/text_light" android:textSize="10sp"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>