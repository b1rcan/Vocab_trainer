<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/bg_page" android:scrollbars="none">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="@color/orange" android:orientation="vertical"
            android:padding="16dp" android:paddingTop="40dp" android:gravity="center">
            <TextView android:id="@+id/tvAvatarInitial" android:layout_width="72dp" android:layout_height="72dp"
                android:background="@drawable/bg_white_btn" android:text="A"
                android:textColor="@color/orange" android:textSize="28sp" android:textStyle="bold"
                android:gravity="center" android:layout_marginBottom="10dp"/>
            <TextView android:id="@+id/tvName" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="Ahmet"
                android:textColor="@color/white" android:textSize="18sp" android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="14dp">

            <!-- Satır 1: Öğrenilen + Toplam -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="10dp">

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:background="@drawable/bg_card"
                    android:orientation="vertical" android:padding="12dp" android:gravity="center"
                    android:layout_marginEnd="5dp">
                    <TextView android:id="@+id/tvStatLearned" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="0"
                        android:textColor="@color/text_main" android:textSize="24sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Öğrenilen" android:textColor="@color/text_gray" android:textSize="11sp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:background="@drawable/bg_card"
                    android:orientation="vertical" android:padding="12dp" android:gravity="center"
                    android:layout_marginStart="5dp">
                    <TextView android:id="@+id/tvStatTotal" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="0"
                        android:textColor="@color/text_main" android:textSize="24sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Toplam" android:textColor="@color/text_gray" android:textSize="11sp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Satır 2: Doğruluk -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:orientation="vertical" android:padding="12dp" android:gravity="center"
                android:layout_marginBottom="10dp">
                <TextView android:id="@+id/tvStatAcc" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="0%"
                    android:textColor="@color/orange" android:textSize="24sp" android:textStyle="bold"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Doğruluk Oranı" android:textColor="@color/text_gray" android:textSize="11sp"/>
            </LinearLayout>

            <!-- Satır 3: Streak -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@drawable/bg_card" android:orientation="horizontal"
                android:gravity="center_vertical" android:padding="14dp" android:layout_marginBottom="10dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="🔥 Günlük Seri"
                    android:textColor="@color/text_main" android:textSize="14sp"/>
                <TextView android:id="@+id/tvStatStreak" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="0 gün"
                    android:textColor="@color/orange" android:textSize="14sp" android:textStyle="bold"/>
            </LinearLayout>

            <!-- Satır 4: Bildirim -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@drawable/bg_card" android:orientation="horizontal"
                android:gravity="center_vertical" android:padding="14dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="🔔 Günlük Hatırlatma"
                    android:textColor="@color/text_main" android:textSize="14sp"/>
                <Switch android:id="@+id/switchNotif" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:checked="true"/>
            </LinearLayout>

            <Button
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_orange_btn"
                android:text="Çıkış Yap"
                android:textAllCaps="false"
                android:textColor="@color/white" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>